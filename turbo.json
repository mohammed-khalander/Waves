{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env":[
        "DATABASE_URL",
        "GROQ_API_KEY",
        "E2B_API_KEY",
        "E2B_ACCESS_TOKEN",
        "CLERK_SECRET_KEY",
        "INNGEST_SIGNING_KEY",
        "INNGEST_EVENT_KEY"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
